{
  "expo": {
    "name": "Museum Findr",
    "slug": "museum-findr",
    "scheme": "museum-findr",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#7C2D28"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.museumfindr.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#7C2D28"
      },
      "package": "com.museumfindr.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/icon.png",
      "name": "Museum Findr",
      "shortName": "MuseumFindr",
      "description": "Discover museums near you",
      "backgroundColor": "#F5F0E8",
      "themeColor": "#7C2D28",
      "display": "standalone",
      "orientation": "portrait",
      "lang": "en"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
